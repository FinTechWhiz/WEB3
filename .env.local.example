# Copy to .env.local for local development. Not required — omitting
# API_BASE_URL makes the site fall back to the static data/stocks.json
# snapshot, which is enough to run the landing page with zero backend.
#
# Set this once backend/ is deployed (e.g. Railway/Render URL, or
# http://localhost:8000 while running `docker compose up` locally).
API_BASE_URL=http://localhost:8000
